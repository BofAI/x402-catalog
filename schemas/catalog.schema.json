{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "x402 public catalog provider",
  "type": "object",
  "required": [
    "version",
    "fqn",
    "title",
    "subtitle",
    "description",
    "useCase",
    "i18n",
    "logo",
    "category",
    "chains",
    "serviceUrl",
    "endpoints"
  ],
  "properties": {
    "version": { "const": 1 },
    "fqn": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,62}$" },
    "title": { "type": "string" },
    "subtitle": { "type": "string" },
    "description": { "type": "string" },
    "useCase": { "type": "string" },
    "logo": { "type": "string" },
    "category": { "type": "string" },
    "chains": { "type": "array", "items": { "$ref": "#/$defs/network" }, "minItems": 1 },
    "isFirstParty": { "type": "boolean" },
    "isFeatured": { "type": "boolean" },
    "featuredTags": { "type": "array", "items": { "type": "string" } },
    "serviceUrl": { "type": "string" },
    "endpoints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "method",
          "path",
          "url",
          "title",
          "subtitle",
          "description",
          "useCase",
          "i18n",
          "metered",
          "minPriceUsd",
          "maxPriceUsd"
        ],
        "properties": {
          "x402Routes": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/x402Route" }
          }
        }
      }
    }
  },
  "$defs": {
    "network": {
      "type": "string",
      "allOf": [
        {
          "if": { "pattern": "^tron:" },
          "then": { "enum": ["tron:0x2b6653dc", "tron:0xcd8690dc", "tron:0x94a9059e"] }
        }
      ]
    },
    "x402Route": {
      "type": "object",
      "required": [
        "provider",
        "network",
        "scheme",
        "url"
      ],
      "properties": {
        "provider": { "type": "string" },
        "network": { "$ref": "#/$defs/network" },
        "scheme": { "enum": ["exact", "exact_gasfree"] },
        "assetTransferMethod": { "const": "permit2" },
        "fee": false,
        "feeConfig": false,
        "url": { "type": "string" }
      },
      "allOf": [
        {
          "if": { "properties": { "scheme": { "const": "exact" } } },
          "then": { "required": ["assetTransferMethod"] }
        },
        {
          "if": { "properties": { "scheme": { "const": "exact_gasfree" } } },
          "then": {
            "properties": {
              "network": { "pattern": "^tron:" }
            },
            "not": { "required": ["assetTransferMethod"] }
          }
        }
      ]
    }
  }
}
